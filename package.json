{
  "name": "dedtxt",
  "productName": "DedTxt",
  "version": "1.0.0-rc.61",
  "description": "DedTxt — a dead simple plain-text editor.",
  "author": {
    "name": "Chris Portka"
  },
  "license": "ISC",
  "homepage": "https://github.com/cportka/dedtxt#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cportka/dedtxt.git"
  },
  "bugs": {
    "url": "https://github.com/cportka/dedtxt/issues"
  },
  "keywords": [
    "text-editor",
    "plain-text",
    "editor",
    "pwa",
    "offline"
  ],
  "scripts": {
    "start": "node scripts/build-icons.js && tauri dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "node --test --test-reporter=spec",
    "gen:icons": "node scripts/build-icons.js",
    "build:mac": "node scripts/build-icons.js && tauri build",
    "build:win": "node scripts/build-icons.js && tauri build",
    "build:linux": "node scripts/build-icons.js && tauri build",
    "build:web": "node scripts/build-icons.js && node scripts/build-web.js",
    "serve:web": "node scripts/build-icons.js && node scripts/build-web.js && npx --yes http-server dist-web -p 5173 -c-1",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "eslint": "^8.57.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5"
  }
}

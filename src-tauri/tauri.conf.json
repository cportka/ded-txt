{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DedTxt",
  "version": "1.0.0-rc.34",
  "identifier": "com.cportka.dedtxt",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DedTxt",
        "width": 900,
        "height": 700,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; manifest-src 'self'; worker-src 'self'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "Copyright (c) 2025 Chris Portka",
    "shortDescription": "A dead simple plain-text editor",
    "longDescription": "DedTxt is a minimal plain-text editor. No formatting, no settings, no fuss.",
    "fileAssociations": [
      { "ext": ["txt"],         "name": "Plain Text", "role": "Editor" },
      { "ext": ["md"],          "name": "Markdown",   "role": "Editor" },
      { "ext": ["log"],         "name": "Log File",   "role": "Editor" },
      { "ext": ["json"],        "name": "JSON",       "role": "Editor" },
      { "ext": ["csv"],         "name": "CSV",        "role": "Editor" },
      { "ext": ["ini"],         "name": "INI",        "role": "Editor" },
      { "ext": ["yml", "yaml"], "name": "YAML",       "role": "Editor" },
      { "ext": ["xml"],         "name": "XML",        "role": "Editor" }
    ]
  }
}
